<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- ライトテーマのブラシ。Dark.xaml と同一のキーを持たせること（片方に欠けると
         テーマ切替時に DynamicResource が解決できず既定色になる）。 -->
    <SolidColorBrush x:Key="WindowBackground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="WindowForeground" Color="#1E1E1E" />
    <SolidColorBrush x:Key="PanelBackground" Color="#F3F3F3" />
    <SolidColorBrush x:Key="BorderBrushColor" Color="#DDDDDD" />
    <SolidColorBrush x:Key="SubtleForeground" Color="#666666" />
</ResourceDictionary>
