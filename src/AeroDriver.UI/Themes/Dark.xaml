<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- ダークテーマのブラシ。Light.xaml と同一のキーを持たせること。 -->
    <SolidColorBrush x:Key="WindowBackground" Color="#1E1E1E" />
    <SolidColorBrush x:Key="WindowForeground" Color="#F0F0F0" />
    <SolidColorBrush x:Key="PanelBackground" Color="#2A2A2A" />
    <SolidColorBrush x:Key="BorderBrushColor" Color="#3F3F46" />
    <SolidColorBrush x:Key="SubtleForeground" Color="#AAAAAA" />
</ResourceDictionary>
