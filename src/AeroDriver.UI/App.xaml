<Application x:Class="AeroDriver.UI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:AeroDriver.UI.Converters">
    <Application.Resources>
        <!-- 明示的なStartupUriは使わず、App.OnStartupでDI経由でMainWindowを生成する -->
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <conv:NullToVisibilityConverter x:Key="NullToVis" />
        <conv:NotNullToVisibilityConverter x:Key="NotNullToVis" />
    </Application.Resources>
</Application>
